---
interface Props {
  title: string
  body: string
}
const { title, body } = Astro.props
---
<article>
  <h3>{title}</h3>
  <p>{body}</p>
</article>

<style>
  article { padding: 1.5rem; border: 1px solid #e2e8f0; border-radius: 0.75rem; background: #fafafa; }
  h3 { margin: 0 0 0.5rem; font-size: 1.1rem; }
  p { margin: 0; color: #475569; font-size: 0.95rem; line-height: 1.5; }
</style>
