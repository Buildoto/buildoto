---
interface Props {
  title: string
}
const { title } = Astro.props
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content="Buildoto — IDE pour la construction avec agent IA, FreeCAD et Git." />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="L'IDE pour le BIM, piloté par IA." />
    <meta property="og:image" content="/og.png" />
    <meta property="og:url" content="https://buildoto.com" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg: #ffffff;
    --fg: #0f172a;
  }
  * { box-sizing: border-box; }
  body { margin: 0; font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: var(--bg); color: var(--fg); }
  a { color: #2563eb; text-decoration: none; }
  a:hover { text-decoration: underline; }
</style>
