{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "buildoto-docs",
  "compatibility_date": "2026-04-21",
  "assets": {
    "directory": "./.vitepress/dist",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "routes": [
    {
      "pattern": "docs.buildoto.com",
      "custom_domain": true
    }
  ]
}
